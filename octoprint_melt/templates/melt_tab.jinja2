<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="row-fluid">
    <div class="span12">
        <h3>Melt Analytics Dashboard</h3>
        <p>Real-time ecosystem metrics bridging your printer to the native Melt apps.</p>
    </div>
</div>

<div class="row-fluid">
    <!-- Health Card -->
    <div class="span4">
        <div class="well">
            <h4>Ecosystem Health</h4>
            <div class="alert alert-info" id="melt-status" style="margin-bottom: 10px;">
                <strong data-bind="text: statusText"></strong>
            </div>
            <p><strong>Active Client Devices:</strong> <span data-bind="text: activeClients"></span></p>
            <p><strong>Telemetry Broadcast:</strong> <span data-bind="text: bytesSent"></span> MB</p>
        </div>
    </div>
    
    <!-- Lifetime Analytics -->
    <div class="span8">
        <div class="well">
            <h4>Lifetime Statistics</h4>
            <div class="row-fluid text-center">
                <div class="span4">
                    <h2 data-bind="text: totalPrints">0</h2>
                    <small>Total Prints</small>
                </div>
                <div class="span4">
                    <h2 data-bind="text: failedPrints">0</h2>
                    <small>Failed Prints</small>
                </div>
                <div class="span4">
                    <h2 data-bind="text: printHours">0</h2>
                    <small>Print Hours</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row-fluid" style="margin-top: 20px;">
    <!-- Telemetry Graph -->
    <div class="span8">
        <h4>Recent Temperature History</h4>
        <div style="background-color: white; border-radius: 5px; padding: 10px;">
            <canvas id="meltTelemetryChart" width="400" height="200"></canvas>
        </div>
    </div>
    
    <!-- Recent Jobs -->
    <div class="span4">
        <h4>Recent Jobs</h4>
        <table class="table table-striped table-condensed">
            <thead>
                <tr>
                    <th>Job ID</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody data-bind="foreach: recentJobs">
                <tr>
                    <td data-bind="text: id"></td>
                    <td>
                        <span class="label" data-bind="text: status, css: {'label-success': status === 'success', 'label-important': status === 'failed', 'label-info': status === 'printing'}"></span>
                    </td>
                </tr>
            </tbody>
        </table>
        <div data-bind="visible: recentJobs().length === 0">
            <em>No recent jobs found.</em>
        </div>
    </div>
</div>
